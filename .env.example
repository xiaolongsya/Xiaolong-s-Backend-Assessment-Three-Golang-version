# Copy this file to `.env` and fill in your own values.
# The server loads `.env` automatically at startup (see cmd/main.go).

# Required: MySQL DSN
# Example (local):
# MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/openai_backend?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_DSN=

# Required: API tokens for Authorization: Bearer <token>
# Multiple tokens are supported via comma-separated list.
API_TOKENS=test-token

# Optional: enable upstream proxy (OpenAI-compatible)
# If not set, the service will use mock responses.
#
# Global upstream (fallback if provider-specific vars are not set)
# UPSTREAM_BASE_URL=https://api.example.com/v1
# UPSTREAM_API_KEY=sk-xxx

# Provider-specific upstream (recommended)
# Provider name comes from ai_models.owned_by (e.g., minimax, volcano)
UPSTREAM_MINIMAX_BASE_URL=
UPSTREAM_MINIMAX_API_KEY=
# UPSTREAM_MINIMAX_API_KEYS=key1,key2

UPSTREAM_VOLCANO_BASE_URL=
UPSTREAM_VOLCANO_API_KEY=
# UPSTREAM_VOLCANO_API_KEYS=key1,key2

# Optional: automatic failover chain when upstream is unavailable
# Format: primary=fallback1,fallback2;another=fallbackX
UPSTREAM_FALLBACKS=volcano=minimax;minimax=volcano

# Optional: file upload storage directory (default: ./data/files)
# FILE_STORAGE_DIR=./data/files

# Optional: Go module proxy (useful in CN)
# GOPROXY=https://goproxy.cn,direct
